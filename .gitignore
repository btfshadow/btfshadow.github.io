```gitignore
# Dependencies
node_modules/

# Environment variables
.env
.env.local
*.env.*

# Logs
*.log

# Coverage reports
coverage/
htmlcov/
.coverage

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS generated files
.DS_Store
Thumbs.db

# Build outputs
dist/
build/
target/
*.out

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Virtual environments
venv/
.venv/
env/
ENV/

# MyPy cache
.mypy_cache/

# Pytest cache
.pytest_cache/

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```